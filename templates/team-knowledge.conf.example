# .team-knowledge.conf — Team Knowledge configuration
# Place this file in the repo root to customize behavior.
# All values are optional — the script auto-detects everything by default.

# Path to TEAM-KNOWLEDGE.md (relative to repo root or absolute)
# Default: searches ../TEAM-KNOWLEDGE.md then ./TEAM-KNOWLEDGE.md
# KNOWLEDGE_FILE="../TEAM-KNOWLEDGE.md"

# Path to state tracking file
# Default: .team-knowledge-state next to KNOWLEDGE_FILE
# STATE_FILE="../.team-knowledge-state"

# Main branch name for tracking changes
# Default: auto-detects dev, main, or master from remote refs
# BASE_BRANCH="dev"

# Project name (used in logs and agent prompts)
# Default: repo directory name
# PROJECT_NAME="my-project"

# Path to the update script
# Default: searches next to KNOWLEDGE_FILE, then global install dirs
# SCRIPT_PATH="../update-team-knowledge.sh"

# Which AI agent CLI to use for updates
# Options: auto (default), claude, cursor, codex, gemini, opencode
# Priority when auto: claude > codex > gemini > cursor > opencode
# AGENT_CLI="auto"
