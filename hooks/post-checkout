#!/bin/bash
# ============================================================
# post-checkout hook — Team Knowledge auto-update
# ============================================================
# Triggers update-team-knowledge.sh when switching to a new feature branch.
# Install: cp this file to .git/hooks/post-checkout && chmod +x .git/hooks/post-checkout
#
# Arguments (provided by git):
#   $1 — previous HEAD ref
#   $2 — new HEAD ref
#   $3 — checkout type: 1 = branch checkout, 0 = file checkout
# ============================================================

PREV_HEAD="$1"
NEW_HEAD="$2"
CHECKOUT_TYPE="$3"

# Only run on branch checkouts, not file checkouts
[ "$CHECKOUT_TYPE" = "1" ] || exit 0

# Skip if heads are the same (no actual branch change)
[ "$PREV_HEAD" != "$NEW_HEAD" ] || exit 0

# --- Locate the update script ---
REPO_DIR=$(git rev-parse --show-toplevel 2>/dev/null)

find_script() {
    # 1. Check .team-knowledge.conf for SCRIPT_PATH
    local conf="$REPO_DIR/.team-knowledge.conf"
    if [ -f "$conf" ]; then
        local script_path
        script_path=$(grep '^SCRIPT_PATH=' "$conf" | cut -d= -f2- | tr -d '"' | tr -d "'")
        if [ -n "$script_path" ]; then
            # Resolve relative paths from repo root
            if [[ "$script_path" != /* ]]; then
                script_path="$REPO_DIR/$script_path"
            fi
            [ -f "$script_path" ] && echo "$script_path" && return 0
        fi
    fi

    # 2. Same directory as TEAM-KNOWLEDGE.md (parent dir)
    local parent_dir
    parent_dir=$(dirname "$REPO_DIR")
    [ -f "$parent_dir/update-team-knowledge.sh" ] && echo "$parent_dir/update-team-knowledge.sh" && return 0

    # 3. Repo root
    [ -f "$REPO_DIR/update-team-knowledge.sh" ] && echo "$REPO_DIR/update-team-knowledge.sh" && return 0

    # 4. Global install
    [ -f "$HOME/.claude/scripts/update-team-knowledge.sh" ] && echo "$HOME/.claude/scripts/update-team-knowledge.sh" && return 0

    return 1
}

SCRIPT=$(find_script) || exit 0

# Run in background so checkout is not blocked
REPO_DIR="$REPO_DIR" nohup bash "$SCRIPT" >> /tmp/team-knowledge-update.log 2>&1 &

exit 0
